{
  "enabled": true,
  "name": "Verificar Build",
  "description": "Ejecuta el build de Vite para verificar que el proyecto compila sin errores. Solo verifica, no modifica nada.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build",
    "timeout": 180
  }
}