# Configuración Base de n8n para Docker
# Renombra o copia este archivo como .env.n8n

# Configuración de zona horaria para precisión en automatizaciones cronológicas
GENERIC_TIMEZONE=America/Santiago

# Configuración de Webhooks Externos
# En desarrollo local con Docker, n8n necesita saber cuál es su URL pública
# por la que Supabase le enviará las peticiones (ya que localhost no expone hacia internet).
# Si usas ngrok (ej: https://tudominio.ngrok-free.app), pega la URL aquí.
WEBHOOK_URL=https://tudominio.ngrok-free.app

# NOTA: Los secretos (Gemini API Key, Supabase Service Role Key) 
# NO deben ir en este archivo. Deben configurarse directamente a través 
# de la interfaz web de n8n en el menú "Credentials". Estos se encriptarán 
# automáticamente y persistirán de forma segura en la carpeta .n8n-data/.
