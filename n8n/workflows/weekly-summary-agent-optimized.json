        "parameters": {
          "values": {
            "string": [
              {
                "name": "automation_id",
                "value": "48a75e32-9015-4394-aa67-750034e0ff0b"
              },
              {
                "name": "run_date",
                "value": "={{ new Date().toISOString() }}"
              }
            ]
          },
          "options": {}
        },
        "id": "config-inicial",
        "name": "Configuracion Inicial",
        "type": "n8n-nodes-base.set",
        "typeVersion": 1,
        "position": [
          200,
          100
        ]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "WITH metricas_7_dias AS (\n  SELECT (NOW() - INTERVAL '7 days') AS limite_fecha\n)\nSELECT\n  json_build_object(\n    'weekly_metrics', json_build_object(\n      'new_leads', (\n         SELECT COUNT(*)::int FROM leads CROSS JOIN metricas_7_dias\n         WHERE created_at >= limite_fecha\n      ),\n      'won_deals_count', (\n         SELECT COUNT(*)::int FROM deals CROSS JOIN metricas_7_dias\n         WHERE LOWER(stage) = 'ganado' AND stage_updated_at >= limite_fecha\n      ),\n      'won_deals_total_value', (\n         SELECT COALESCE(SUM(value), 0)::numeric FROM deals CROSS JOIN metricas_7_dias\n         WHERE LOWER(stage) = 'ganado' AND stage_updated_at >= limite_fecha\n      ),\n      'active_high_risk_deals', (\n         SELECT COUNT(*)::int FROM deals\n         WHERE ai_risk_level IN ('High', 'Critical')\n      ),\n      'pending_critical_tasks', (\n         SELECT COUNT(*)::int FROM tasks\n         WHERE LOWER(status) != 'completada' AND priority = 'Alta'\n      ),\n      'active_deals_total', (\n         SELECT COUNT(*)::int FROM deals\n         WHERE LOWER(stage) NOT IN ('ganado', 'perdido')\n      )\n    ),\n    'generated_at', NOW()\n  ) AS payload;"
        },
        "id": "postgres-node",
        "name": "Extraer Metricas SQL",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.2,
        "position": [
          420,
          100
        ],
        "credentials": {
          "postgres": {
            "id": "REEMPLAZAR_EN_UI",
            "name": "Postgres (Supabase DB)"
          }
        }
      },
      {
        "parameters": {
          "conditions": {
            "number": [
              {
                "value1": "={{ ($json.payload?.weekly_metrics?.new_leads ?? 0) + ($json.payload?.weekly_metrics?.won_deals_count ?? 0) + ($json.payload?.weekly_metrics?.active_deals_total ?? 0) }}",
                "operation": "larger",
                "value2": 0
              }
            ]
          }
        },
        "id": "if-empty-validation",
        "name": "IF Validacion Vacia",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
