        "id": "wa-if-lead-exists-001",
        "name": "¿Lead existe?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [1100, 240]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://kgrfhfwtcanthrymmvkb.supabase.co/rest/v1/leads",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
                "value": "={{ $credentials.supabaseApi.serviceKey }}"
              },
              {
                "name": "Authorization",
                "value": "=Bearer {{ $credentials.supabaseApi.serviceKey }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Prefer",
                "value": "return=representation"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={ \"full_name\": \"WhatsApp: {{ $('Extraer Datos Mensaje').item.json.phone }}\", \"phone\": \"{{ $('Extraer Datos Mensaje').item.json.phone }}\", \"source\": \"whatsapp\", \"status\": \"nuevo\" }",
          "options": {}
        },
        "id": "wa-create-lead-001",
        "name": "Crear Lead Nuevo",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 3,
        "position": [1320, 400]
      },
      {
        "parameters": {
          "jsCode": "// Merge lead data from either branch\nconst extractNode = $('Extraer Datos Mensaje').item.json;\n\nlet leadData = null;\n\n// Try to get from search result first\ntry {\n  const searchResult = $('Buscar Lead por Teléfono').item.json;\n  if (Array.isArray(searchResult) && searchResult.length > 0) {\n    leadData = searchResult[0];\n  }\n} catch(e) {}\n\n// If no search result, try create result\nif (!leadData) {\n  try {\n    const createResult = $('Crear Lead Nuevo').item.json;\n    if (Array.isArray(createResult) && createResult.length > 0) {\n      leadData = createResult[0];\n    } else if (createResult && createResult.id) {\n      leadData = createResult;\n    }\n  } catch(e) {}\n}\n\nreturn [{\n  json: {\n    lead_id: leadData?.id || null,\n    lead_name: leadData?.full_name || 'Cliente nuevo',\n    lead_score: leadData?.ai_score || null,\n    lead_category: leadData?.ai_category || null,\n    phone: extractNode.phone,\n    message: extractNode.message,\n    wa_message_id: extractNode.wa_message_id\n  }\n}];"
        },
        "id": "wa-merge-lead-001",
        "name": "Normalizar Datos Lead",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [1540, 240]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://kgrfhfwtcanthrymmvkb.supabase.co/rest/v1/whatsapp_conversations",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
                "value": "={{ $credentials.supabaseApi.serviceKey }}"
              },
              {
                "name": "Authorization",
