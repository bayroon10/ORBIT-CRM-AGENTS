              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Prefer",
                "value": "return=minimal"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ { \"lead_id\": $json.lead_id, \"phone\": $json.phone, \"direction\": \"inbound\", \"message\": $json.message, \"wa_message_id\": $json.wa_message_id, \"ai_generated\": false } }}",
          "options": {}
        },
        "id": "wa-log-inbound-001",
        "name": "Registrar Mensaje Entrante",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 3,
        "position": [1760, 240]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{ $credentials.googlePalmApi.apiKey }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ { \"contents\": [{ \"parts\": [{ \"text\": \"Eres el asistente de ventas de Orbit CRM. Responde en español de forma concisa (máximo 3 oraciones).\\n\\nContexto del cliente:\\n- Nombre: \" + ($('Normalizar Datos Lead').item.json.lead_name) + \"\\n- Score IA: \" + ($('Normalizar Datos Lead').item.json.lead_score || 'Sin evaluar') + \"\\n- Categoría: \" + ($('Normalizar Datos Lead').item.json.lead_category || 'Sin categoría') + \"\\n\\nMensaje recibido: \" + ($('Normalizar Datos Lead').item.json.message) + \"\\n\\nResponde de forma útil y profesional.\" }] }], \"generationConfig\": { \"maxOutputTokens\": 2000, \"temperature\": 0.7 } } }}",
          "options": {}
        },
        "id": "wa-gemini-001",
        "name": "Gemini — Generar Respuesta",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 3,
        "position": [1980, 240]
      },
      {
        "parameters": {
          "jsCode": "const response = $input.first().json;\nlet text = '';\ntry {\n  text = response.candidates[0].content.parts[0].text;\n} catch(e) {\n  text = 'Hola, gracias por contactarnos. Un agente te atenderá pronto.';\n}\nreturn [{ json: { ai_response: text.trim() } }];"
        },
