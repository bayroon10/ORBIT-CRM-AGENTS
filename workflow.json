        [
          { "node": "Parsear JSON de IA", "type": "main", "index": 0 }
        ]
      ]
    },
    "Parsear JSON de IA": {
      "main": [
        [
          { "node": "Guardar en Supabase", "type": "main", "index": 0 }
        ]
      ]
    },
    "Guardar en Supabase": {
      "main": [
        [
          { "node": "Confirmar", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {}
}
